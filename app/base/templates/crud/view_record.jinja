{#- app/base/templates/crud/view_record.jinja -#}
{%- from 'macros/datadict-dbman.jinja' import DatadictDBMan -%}
{%- extends 'base.jinja' -%}

{%- block head -%}
  <meta name="modules" content="">
{%- endblock head -%}

{#- @param for base.jinja - prev_page: redirect to upper level page -#}
{%- set prev_page = url_for('base.crud.index') -%}

{%- block content %}
  <div class="container-fluid d-flex flex-wrap">
    <div class="row">
      <nav id="navbar-view" class="navbar navbar-expand-lg navbar-light bg-light">
        <ul class="nav">
          <li class="nav-item dropdown">
            <button class="btn dropdown-toggle" 
              data-bs-toggle="dropdown" 
              role="button" aria-expanded="false">
              {{- _('Related Objects') -}}
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="#">Object 1</a></li>
            </ul>
          </li>
          <li class="nav-item dropdown">
            <button class="btn dropdown-toggle" 
               data-bs-toggle="dropdown" 
               href="#" role="button" aria-expanded="false">
              {{- _('Related Functions') -}}
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="#">Func 1</a></li>
            </ul>
          </li>
        </ul>
      </nav>
    </div>
    <div class="row">
      <div class="col-12 d-flex p-3 border fixed-fill">
        <div class="col-sm-12 col-md-6 mt-2 p-3 border independent-scroll">
          <h4>{{- _('Basic Information') -}}</h4>
          {{- DatadictDBMan(
                name='basic',
                data=basic_info,
                ref_names=ref_names,
                data_keys=headers,
                datajson_keys={}
              ) 
          -}}
        </div>
        <div class="col-sm-12 col-md-6 mt-2 p-3 border independent-scroll">
          <h4>{{- _('Related Objects') -}}</h4>
          <p>{{ ref_names }}</p>
          <h4>{{- _('Related Functions') -}}</h4>
          <p>{{ ref_lists }}</p>
        </div>
      </div>
    </div>
  </div>
   
{%- endblock content -%}
