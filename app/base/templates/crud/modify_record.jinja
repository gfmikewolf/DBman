{#- app/base/templates/crud/modify_record.jinja -#}
{#-
  @params:
    table_name,
    pks: str = comma joined primary keys,
    select_options={fk_col_name: ((pks, name)...)},
    date_keys: set(str),
    longtext_keys: set(str),
    datajson_keys: set(str),
    required_keys: set(str),
    readonly_keys: set(str),
    data: dict(key, value)
-#}
{%- from 'macros/modal-dbman.jinja' import ModalDBMan -%}
{%- extends "base.jinja" -%}
{%- set prev_page = url_for('base.crud.view_table', table_name=table_name) -%}
{%- block head %}
  <meta name="modules" content="form-modify,modal-alert">
{%- endblock head -%}
{%- block content %}
<div class="container-fluid">
  <div class="row">
    <h5 class="mt-3">
      {{- _('Modify Record') }}
      [{{- table_name -}}] id={{- pks if pks != '_new' else _('Create New Record') }}
    </h5>
    <div class="col col-sm-12 col-md-8 col-lg-6 mt-3">
      <form method="post" id="dbman-modify-main" class="needs-validation" novalidate>
        <div class="card">
          <div class="card-header">
            {{- _('_enter_form_data') -}}
          </div>
          <div class="card-body">
            {%- for key in headers -%}
            {%- set value = data[key] %}
            <div class="input-group mb-3 flex-nowrap">
              <label class="input-group-text" for="{{ key }}">
                {{- key -}}
                {%- if key in required_keys -%}
                <div class="text-danger">*</div>
                {%- endif -%}
              </label>
              {%- if key in date_keys %}
              <input {{ 'name="' + key + '"' if key not in readonly_keys }}
                     type="date"
                     class="form-control"
                     id="{{ key }}"
                     value="{{- '' if pks == '_new' else value -}}"
                     {{ 'required' if key in required_keys }}
                     {{ 'readonly' if key in readonly_keys }}>
              {%- elif key in select_options.keys() -%}
              {%- set options = select_options[key] -%}
              {%- set is_long_options = options|length > 5 -%}
              {%- if is_long_options %}
              <div class="mj-selectpicker">
                <input type="search" class="form-control" placeholder="🔍" id="{{ key }}-search">
              {%- endif %}
              <select {{ 'name="' + key + '"' if key not in readonly_keys }}
                      class="form-select"
                      id="{{ key }}"
                      {{ 'required' if key in required_keys }}
                      {{ 'readonly' if key in readonly_keys }}>
                <option value="" {{ 'selected' if pks=="_new" else '' }} hidden>
                  {{ _('Please select') -}}
                </option>
                {%- for option in options %}
                <option value="{{- option[0] -}}"
                  {%- if pks and value|string == option[0]|string -%}
                  selected
                  {%- endif -%}>
                  {{- option[1] -}}
                </option>
                {%- endfor %}
              </select>
              {%- if is_long_options %}
              </div>
              {%- endif -%}
              {%- elif key in datajson_ref_map.keys() %}
              <textarea id="{{ key }}" name="{{ key }}" class="form-control" 
                row="3" value='{{ value }}' readonly>{{- value -}}</textarea>
              </div><div class="container-fluid">
              <div id="dbman-datajson-{{ key }}" class="dbman-datajson" data-dbman-data="{{ value }}"></div>
              {%- elif key in longtext_keys %}
              <textarea {{ 'name="' + key + '"' if key not in readonly_keys }}
                        id="{{- key -}}"
                        class="form-control"
                        rows="{{- 3 if value is none or value == '' else ((value|length)/40)|round|int + 1 -}}"
                        {{ 'required pattern=".*\S.*"' if key in required_keys }}
                        {{ 'readonly' if key in readonly_keys }}>
                {{- '' if pks == '_new' else value -}}
              </textarea>
              {%- else %}
              <input {{ 'name="' + key + '"' if key not in readonly_keys }}
                     type="text"
                     class="form-control"
                     id="{{- key -}}"
                     value="{{- '' if pks == '_new' else value -}}"
                     {{ 'required pattern=".*\S.*"' if key in required_keys }}
                     {{ 'readonly' if key in readonly_keys }}>
              <div class="invalid-feedback">
                {{- _('Please enter a meaningful string') -}}
              </div>
              {%- endif %}
            </div>
            {%- endfor %}
          </div>
        </div>
        <div class="d-flex justify-content-end w-100 mt-2">
          <a href="{{- url_for('base.crud.view_table', table_name=table_name) -}}"
             class="btn btn-outline-dark mx-2">
            {{- _('Cancel') -}}
          </a>
          <button type="submit" class="btn btn-outline-dark mx-2">
            {{- _('Save Changes') -}}
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
{%- endblock content -%}
{%- block alert -%}
  {{- ModalDBMan(
    name='main',
    type='dbman-alert',
    title=_('Alert'),
    msgs={
      'success': [_('Success'), _('Operation Successful. _in3seconds, redirecting to View Table')],
      'error': [_('Error'), _('Operation Error')],
      'warning_delete': [_('Alert'), _('_warning_delete')],
      'nochange': [_('Records unchanged'), _('Cannot find any changes.')]
    }
  ) -}}
{%- endblock alert -%}
{%- block scripts -%}
<script>
  var fromTemplate = {}
  fromTemplate['datajson_ref_map'] = {{ datajson_ref_map }};
</script>
{%- endblock scripts -%}
