{# app/base/templates/crud/modify_record.jinja #}
{#
    @params:
        table_name,
        pks: str = comma joined primary keys,
        ref_pks_name={fk_col_name: ((pks, name)...)}
        date_keys: set(str),
        longtext_keys: set(str),
        datajson_keys: set(str),
        required_keys: set(str),
        readonly_keys: set(str),
        data: dict(key, value)
#}
{%- extends "base.jinja" -%}
{%- set prev_page = url_for('base.crud.view_table', table_name=table_name) -%}
{%- block content -%}
<div class="container-fluid">
    <div class="row">
        <h5 class="mt-3">{{ _('Modify Record') }}  [{{ table_name }}] id={{ pks if pks != '_new' else _('Create New Record') }}</h5>
        <div class="col col-sm-12 col-md-8 col-lg-6 mt-3">
            <form method="post" id="form-modify-main">
                <div class="card">
                    <div class="card-header">{{ _('_enter_form_data') }}</div>
                    <div class="card-body">
                    {%- for key in headers -%}
                        {%- set value = data[key] -%}
                        <div class="input-group mb-3">
                            <label class="input-group-text">
                                {{ key }}
                                {%- if key in required_keys -%}
                                <div class="text-danger">*</div>
                                {%- endif -%}
                            </label>
                            {%- if key in date_keys -%}
                                <input type="date" class="form-control" name="{{ key }}" value="{{ '' if pks =='_new' else value }}" {{ 'required' if key in required_keys }}>
                            {%- elif key in ref_pks_name.keys() -%}
                                <select class="form-select" name="{{ key }}" {{ 'required' if key in required_keys }}>
                                {%- for option in ref_pks_name[key] -%}
                                    <option value="{{ option[0] }}" 
                                    {%- if pks and value == option[0]|string -%}
                                        selected
                                    {%- endif -%}>
                                        {{ option[1] }}
                                    </option>
                                {%- endfor -%}
                                </select>
                            {%- elif key in datajson_keys -%}
                                <div>json place holder</div>
                            {%- elif key in longtext_keys -%}
                                <textarea name="{{ key }}" class="form-control" rows="{{ ((value|length)/40)|round|int + 1 }}">{{ '' if pks == '_new' else value }}</textarea>
                            {%- else -%}
                                <input type="text" class="form-control" name="{{ key }}" value="{{ '' if pks == '_new' else value }}" {{ 'required' if key in required_keys }}>
                            {%- endif -%}
                        </div>                    
                    {%- endfor -%}
                    </div>
                </div>
                <div class="d-flex justify-content-end w-100 mt-2">
                    <a href="{{ url_for('base.crud.view_table', table_name=table_name) }}" class="btn btn-outline-dark mx-2">{{ _('Cancel') }}</a>
                    <button type="submit" class="btn btn-outline-dark mx-2">{{ _('Save Changes') }}</button>
                </div>
            </form>
        </div>
    </div>
</div>
{%- endblock -%}
{%- block scripts -%}{%- endblock -%}
