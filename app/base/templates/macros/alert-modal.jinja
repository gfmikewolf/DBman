{# app/base/templates/macros/alert-modal.jinja #}
{%- macro alert_modal(
        id='alert-modal',
        title=_('Alert'), 
        msg_titles={
            'success': _('Operation Success'),
            'error': _('Operation Error'),
            'warning_delete': _('_warning_delete')
        }
        extra_btns={
            'confirm': _('Confirm'),
            'back': _('_return_to_viewtable')
        }
    ) 
-%}
<div class="modal fade" id="{{ id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ title }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {%- for key in msg_titles -%}
                <span class="d-none" data-msg-title="{{ key|lower }}">{{ msg_titles[key] }}: </span>
                {%- endfor -%}
                <span data-msg-body></span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal" data-am-close>
                    {{ _('Close') }}
                </button>
                {%- for key in extra_btns -%}
                <button type="button" class="btn btn-outline-dark d-none" data-am-{{ key|lower }}>
                    {{ extra_btns[key] }}
                </button>
                {%- endfor -%}
            </div>
        </div>
    </div>
</div>
{%- endmacro %}