{# app/base/templates/macros/modal-dbman.jinja #}
{%- from 'macros/dragcontainer-dbman.jinja' import DragContainerDBMan -%}
{%- macro ModalDBMan(
        id='modal-dbman',
        type='datatable-modal-config',
        title='modal-title',
        data=[]
    )
-%}
{%- set valid_types = ('datatable-modal-config', 'modal-alert') -%}
{%- if type in valid_types -%}
<div class="modal fade" id="{{ id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ title }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {%- if type == 'datatable-modal-config' -%}
                {{ DragContainerDBMan(type='card', title=_('_table_header'), data=data) }}
                {%- endif -%}
            </div>
            <div class="modal-footer">
                {%- if type == 'modal-alert' -%}
                <button type="button" class="btn btn-sm btn-outline-dark" data-dbman-toggle="confirm">{{ _('Confirm') }}</button>
                {%- endif -%}
                {%- if type == 'datatable-modal-config' -%}
                <button type="button" class="btn btn-sm btn-outline-dark" data-dbman-toggle="restore-default">{{ _('Restore Default') }}</button>
                <button type="button" class="btn btn-sm btn-outline-dark" data-dbman-toggle="save-changes">{{ _('Save Changes') }}</button>
                {%- endif -%}
            </div>
        </div>
    </div>
</div>
{%- endif -%}
{%- endmacro -%}
{#
{%- macro ModalDBman(
        id='modal-dbman',
        type='alert',
        title=_('Modal Title'), 
        msg_titles={
            'success': _('Operation Success'),
            'error': _('Operation Error'),
            'warning_delete': _('_warning_delete')
        }
        extra_btns={
            'confirm': _('Confirm'),
            'back': _('_return_to_viewtable')
        }
    ) 
-%}

<div class="modal fade" id="{{ id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ title }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {% if type == 'table-config'%}
                {%- for key in msg_titles -%}
                <span class="d-none" data-msg-title="{{ key|lower }}">{{ msg_titles[key] }}: </span>
                {%- endfor -%}
                <span data-msg-body></span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal" data-am-close>
                    {{ _('Close') }}
                </button>
                {%- for key in extra_btns -%}
                <button type="button" class="btn btn-outline-dark d-none" data-am-{{ key|lower }}>
                    {{ extra_btns[key] }}
                </button>
                {%- endfor -%}
            </div>
        </div>
    </div>
</div>
{%- endmacro %}
#}